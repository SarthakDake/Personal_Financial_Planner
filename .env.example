# Application
APP_NAME=Professional Financial Planner
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret-key
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database — SQLite for development; switch to PostgreSQL for production
DATABASE_URL=sqlite:///./data/financial_planner.db
# DATABASE_URL=postgresql+psycopg2://fp_user:fp_password@localhost:5432/financial_planner

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Paths
CONFIG_DIR=./config
REPORTS_DIR=./output/reports
CHARTS_DIR=./output/charts
SAMPLE_DATA_DIR=./sample_data

# Advisor branding (configurable — not client data)
ADVISOR_FIRM_NAME=WealthCraft Advisors
ADVISOR_FIRM_TAGLINE=Clarity. Discipline. Prosperity.
ADVISOR_CONTACT_EMAIL=advisor@wealthcraft.example
ADVISOR_CONTACT_PHONE=+91-00000-00000

# Logging
LOG_LEVEL=INFO
